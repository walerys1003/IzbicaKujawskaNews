# =============================================================================
# izbica24 Newsroom — n8n VPS configuration
# Skopiuj do `.env` i uzupełnij sekrety:    cp .env.example .env
# =============================================================================

# --- HTTP / TLS ---
N8N_HOST=n8n.izbica24.pl
ACME_EMAIL=admin@izbica24.pl

# --- Postgres (lokalny) ---
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_strong_password_min_32_chars

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- n8n encryption key (uruchom: openssl rand -hex 32) ---
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# --- izbica24 portal (WordPress REST API) ---
IZBICA24_BASE_URL=https://izbica24.pl
IZBICA24_API_TOKEN=CHANGE_ME_token_z_wp_iz24_token_generate

# --- AI providers ---
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=

# --- Telegram (opcjonalnie) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
