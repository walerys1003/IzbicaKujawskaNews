{
    "name": "izbica24/newsroom",
    "description": "AI-driven newsroom for izbica24.pl WordPress portal",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "wp-coding-standards/wpcs": "^3.0",
        "squizlabs/php_codesniffer": "^3.7",
        "mpdf/mpdf": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Izbica24\\Newsroom\\": "includes/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs --standard=WordPress includes/"
    }
}
